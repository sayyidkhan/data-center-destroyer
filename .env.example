# Vite environment variables
# https://vitejs.dev/guide/env-and-mode.html

# Deployment used by npx convex dev
CONVEX_DEPLOYMENT=prod:<your-deployment-slug> # team: <your-team>, project: <your-project>

# Convex backend
VITE_CONVEX_URL=https://<your-deployment-slug>.convex.cloud
VITE_CONVEX_SITE_URL=https://<your-deployment-slug>.convex.site

# Multiplayer settings
VITE_COUNTDOWN_SECONDS=3
VITE_MAX_PLAYERS_PER_ROOM=4
VITE_ROOM_CODE_LENGTH=6

# OpenAI Speech-to-Text
# Copy this file to .env and set your real key.
# Frontend-only hackathon mode: VITE_ exposes this key to browser code.
# Never commit real API keys.
VITE_OPENAI_API_KEY=sk-...

# Optional: Analytics / Monitoring
# VITE_ANALYTICS_ID=
